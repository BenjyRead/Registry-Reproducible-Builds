FROM node:20-alpine

RUN apk add --no-cache git

WORKDIR /app

RUN git init && \
    git remote add origin https://github.com/prettier/prettier.git && \
    git fetch --depth 1 origin 7584432401a47a26943dd7a9ca9a8e032ead7285 && \
    git checkout FETCH_HEAD

RUN yarn install --immutable

RUN yarn build

# Remove scripts field from package.json to match official package
RUN node -e " \
    const fs = require('fs'); \
    const p = JSON.parse(fs.readFileSync('dist/package.json')); \
    delete p.scripts; \
    fs.writeFileSync('dist/package.json', JSON.stringify(p, null, 2)); \
    "

# Fix permissions to match the official published package
RUN chmod -x dist/bin/prettier.cjs

RUN mkdir -p /out && cd dist && npm pack --pack-destination /out

CMD ["sh", "-c", "ls /out/*.tgz"]
