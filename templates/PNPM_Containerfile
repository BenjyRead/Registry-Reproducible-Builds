# -- Build Stage --
FROM {{index . "NODE_IMAGE" | default "node:23-alpine"}} AS build

RUN apk add --no-cache git pnpm

WORKDIR /app

# Since tags can be moved, we fetch the specific commit instead.
RUN git clone {{.REPO_URL}} .
RUN git fetch --depth 1 origin {{.COMMIT_SHA}}
RUN git checkout {{.COMMIT_SHA}}

RUN pnpm install --frozen-lockfile
RUN pnpm build --filter ./{{.BUILD_DIR}}

# pnpm pack generate tgz file
RUN cd {{.BUILD_DIR}} && \
    pnpm pack --pack-destination /out

# Testing diffoscope works
# RUN printf '\n' >> /tmp/svelte-5.48.2.tgz

# -- Pull Stage --
FROM {{index . "NODE_IMAGE" | default "node:23-alpine"}} AS official

RUN apk add --no-cache wget

RUN mkdir -p /out
RUN wget {{.OFFICIAL_TGZ_URL}} -O /out/official.tgz

# -- Compare Stage --
FROM {{index . "ALPINE_IMAGE" | default "alpine:3.23"}}

RUN apk add --no-cache diffoscope

COPY --from=build /out/*.tgz /tmp/build.tgz
COPY --from=official /out/official.tgz /tmp/official.tgz

CMD sh -c "\
    set -x; \
    diffoscope /tmp/build.tgz /tmp/official.tgz > /tmp/diffoscope.txt; \
    if [ -s /tmp/diffoscope.txt ]; then \
    echo 'Reproducible Build Test Failed'; \
    echo 'Diffoscope Output:'; \
    cat /tmp/diffoscope.txt; \
    exit 1; \
    else \
    echo 'Reproducible Build Test Passed'; \
    exit 0; \
    fi"
