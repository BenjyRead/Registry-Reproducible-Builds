# -- Build Stage --
FROM node:23-alpine AS build

RUN apk add --no-cache git

WORKDIR /app

# Since tags can be moved, we fetch the specific commit instead.
# Only fetching the specific commit for efficiency, as the TypeScript repo is quite large.
RUN git init && \
    git remote add origin https://github.com/microsoft/TypeScript.git && \
    git fetch --depth 1 origin c63de15a992d37f0d6cec03ac7631872838602cb && \
    git checkout FETCH_HEAD

RUN npm ci --frozen-lockfile

RUN npm run build

# pnpm pack generate tgz file
RUN mkdir -p /out && \
    # Extremely hacky way to inject gitHead field into package.json. Typescript has a very complex pipeline system, and some part of it injects this field during the build, easier to just inject it manually here than to try to reproduce the exact same pipeline in our build system.
    node -e "const p=require('./package.json'); p.gitHead='c63de15a992d37f0d6cec03ac7631872838602cb'; require('fs').writeFileSync('package.json', JSON.stringify(p, null, 4) + '\n')" && \
    npm pack --pack-destination /out

# Testing diffoscope works
# RUN printf '\n' >> /tmp/svelte-5.48.2.tgz

# -- Pull Stage --
FROM node:23-alpine AS official

RUN apk add --no-cache wget

RUN mkdir -p /out
# RUN wget https://github.com/microsoft/TypeScript/releases/download/v5.9.3/typescript-5.9.3.tgz -O /out/official.tgz
RUN wget https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz -O /out/official.tgz

# -- Compare Stage --
FROM alpine:3.23

RUN apk add --no-cache diffoscope

COPY --from=build /out/*.tgz /tmp/build.tgz
COPY --from=official /out/official.tgz /tmp/official.tgz

CMD sh -c "\
    set -x; \
    diffoscope /tmp/build.tgz /tmp/official.tgz > /tmp/diffoscope.txt; \
    if [ -s /tmp/diffoscope.txt ]; then \
    echo 'Reproducible Build Test Failed'; \
    echo 'Diffoscope Output:'; \
    cat /tmp/diffoscope.txt; \
    exit 1; \
    else \
    echo 'Reproducible Build Test Passed'; \
    exit 0; \
    fi"
